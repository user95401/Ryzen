{
	"geode": "1.3.6",
	"version": "${version}",
	"id": "${developer}.${PROJECT_NAME}",
	"name": "${PROJECT_NAME}",
	"developer": "${developer}",
	"description": "${description}",
	"repository": "${repository}",
	"issues": {
		"url": "${issues_url}",
		"info": "${issues_info}"
	},
	"resources": {
		"files": [
			"Resources/*"
		],
		"sprites": [
			"Resources/*"
		]
	},
	"settings": {
		"header": {
			"name": "                    ",
			"type": "color",
			"default": "#1d1d1d"
		},
		"sprites_list.ini": {
			"name": "Ryzen.ini (load mod first)",
			"description": "open up Ryzen.ini",
			"type": "color",
			"default": "#1d1d1d"
		},
		"Auto calculation": {
			"name": "dntloadmods 6525",
			"description": "open up dntloadmods value popup...",
			"type": "color",
			"default": "#1d1d1d"
		},
		"Disable auto updating": {
			"name": "dntupadatemod 6525",
			"description": "open up dntupadatemod value popup...",
			"type": "color",
			"default": "#1d1d1d"
		},
		"footer": {
			"name": "                    ",
			"type": "color",
			"default": "#1d1d1d"
		}
	}
}