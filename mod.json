{
	"geode": "3.0.0-beta.1",
	"gd": {
		"win": "2.206",
		"android": "*"
	},
	"version": "v0.0.0",
	"id": "user95401.ryzen",
	"name": "Ryzen | Mods & TPs Place",
	"developer": "user95401",
	"description": "Brings a standalone catalog for any mods and resource packs.",
	"repository": "https://github.com/user95401/Ryzen",
	"early-load": true,
	"dependencies": [
		{
			"id": "geode.texture-loader",
			"version": ">=v1.5.0",
			"importance": "suggested"
		}
	],
	"resources": {
		"files": [ "files/*" ],
		"sprites": [ "sprites/*.png", "*.png" ]
	},
	"settings": {
		"issues_repo": {
			"name": "Issues repo",
			"type": "string",
			"default": "user95401/Ryzen-Mods"
		},
		"per_page": {
			"name": "Items per page",
			"type": "int",
			"default": 50
		}
	}
}